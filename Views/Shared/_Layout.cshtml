<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="site-nav navbar navbar-expand-md fixed-top" id="mainNav">
        <div class="container">
            @{
                var layoutTitles = ViewData["LayoutTitles"] as LayoutTitles ?? new();
            }
            <a class="navbar-brand fw-semibold" href="#hero">@layoutTitles.BrandName</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu"
                    aria-controls="navMenu" aria-expanded="false" aria-label="Toggle navigation">
                <i class="bi bi-list"></i>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto gap-1">
                    @{
                        var navSections = ViewData["SectionSettings"] as List<SectionSetting> ?? new();
                    }
                    @foreach (var s in navSections.Where(s => s.Enabled && s.Key != "hero").OrderBy(s => s.Order))
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="#@s.Key">@(char.ToUpper(s.Key[0]) + s.Key[1..])</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer text-center py-4">
        <div class="container">
            <p class="mb-0 text-muted small">
                @layoutTitles.FooterText &mdash; &copy; @DateTime.Now.Year @layoutTitles.FooterCredit
            </p>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
