@using System.Collections.Generic
@{
    var layoutTitles = ViewData["LayoutTitles"] as VivanPortfolio.Models.LayoutTitles ?? new();
    var navSections = ViewData["SectionSettings"] as List<SectionSetting> ?? new();
    var seo = ViewData["SeoSettings"] as VivanPortfolio.Models.SeoSettings ?? new();
    var profile = ViewData["Profile"] as VivanPortfolio.Models.Profile ?? new();

    var pageTitle = !string.IsNullOrEmpty(seo.Title) ? seo.Title : (ViewData["Title"]?.ToString() ?? "");
    var baseUrl = seo.SiteUrl.TrimEnd('/');
    var canonicalUrl = string.IsNullOrEmpty(baseUrl) ? "" : baseUrl + "/";
    var ogImageUrl = (!string.IsNullOrEmpty(baseUrl) && !string.IsNullOrEmpty(seo.OgImage))
        ? baseUrl + seo.OgImage
        : "";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle</title>

    @* Core SEO *@
    @if (!string.IsNullOrEmpty(seo.Description))
    {
        <meta name="description" content="@seo.Description" />
    }
    @if (!string.IsNullOrEmpty(seo.Keywords))
    {
        <meta name="keywords" content="@seo.Keywords" />
    }
    @if (!string.IsNullOrEmpty(seo.Author))
    {
        <meta name="author" content="@seo.Author" />
    }
    @if (!string.IsNullOrEmpty(seo.Robots))
    {
        <meta name="robots" content="@seo.Robots" />
    }
    @if (!string.IsNullOrEmpty(canonicalUrl))
    {
        <link rel="canonical" href="@canonicalUrl" />
    }

    @* Open Graph *@
    @if (!string.IsNullOrEmpty(canonicalUrl))
    {
        <meta property="og:type" content="@(string.IsNullOrEmpty(seo.OgType) ? "website" : seo.OgType)" />
        <meta property="og:url" content="@canonicalUrl" />
        <meta property="og:title" content="@pageTitle" />
        @if (!string.IsNullOrEmpty(seo.Description))
        {
            <meta property="og:description" content="@seo.Description" />
        }
        @if (!string.IsNullOrEmpty(ogImageUrl))
        {
            <meta property="og:image" content="@ogImageUrl" />
        }
    }

    @* Twitter Card *@
    @if (!string.IsNullOrEmpty(seo.TwitterCard))
    {
        <meta name="twitter:card" content="@seo.TwitterCard" />
        @if (!string.IsNullOrEmpty(seo.TwitterHandle))
        {
            <meta name="twitter:site" content="@seo.TwitterHandle" />
            <meta name="twitter:creator" content="@seo.TwitterHandle" />
        }
        <meta name="twitter:title" content="@pageTitle" />
        @if (!string.IsNullOrEmpty(seo.Description))
        {
            <meta name="twitter:description" content="@seo.Description" />
        }
        @if (!string.IsNullOrEmpty(ogImageUrl))
        {
            <meta name="twitter:image" content="@ogImageUrl" />
        }
    }

    @* JSON-LD Person Schema *@
    @if (seo.Schema.Enabled && !string.IsNullOrEmpty(profile.Name))
    {
        var sameAsList = new List<string>();
        if (!string.IsNullOrEmpty(profile.LinkedInUrl)) sameAsList.Add(profile.LinkedInUrl);
        if (!string.IsNullOrEmpty(profile.GitHubUrl)) sameAsList.Add(profile.GitHubUrl);
        if (!string.IsNullOrEmpty(profile.UpworkUrl)) sameAsList.Add(profile.UpworkUrl);
        if (!string.IsNullOrEmpty(profile.FiverrUrl)) sameAsList.Add(profile.FiverrUrl);
        if (!string.IsNullOrEmpty(profile.ToptalUrl)) sameAsList.Add(profile.ToptalUrl);

        var schema = new Dictionary<string, object>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "Person",
            ["name"] = profile.Name,
            ["jobTitle"] = profile.Title,
            ["url"] = canonicalUrl,
            ["email"] = profile.Email,
            ["address"] = new Dictionary<string, string>
            {
                ["@type"] = "PostalAddress",
                ["addressLocality"] = profile.Location
            },
            ["sameAs"] = sameAsList
        };
        var schemaJson = System.Text.Json.JsonSerializer.Serialize(schema,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = false });
        <script type="application/ld+json">@Html.Raw(schemaJson)</script>
    }

    @if (!string.IsNullOrEmpty(layoutTitles.Favicon))
    {
        <link rel="icon" type="image/x-icon" href="@layoutTitles.Favicon" />
    }
    @if (!string.IsNullOrEmpty(layoutTitles.TouchIcon))
    {
        <link rel="icon" type="image/png" sizes="512x512" href="@layoutTitles.TouchIcon" />
        <link rel="apple-touch-icon" href="@layoutTitles.TouchIcon" />
    }
    <script type="importmap"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="site-nav navbar navbar-expand-md fixed-top" id="mainNav">
        <div class="container">
            <a class="navbar-brand fw-semibold" href="#hero">@layoutTitles.BrandName</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu"
                    aria-controls="navMenu" aria-expanded="false" aria-label="Toggle navigation">
                <i class="bi bi-list"></i>
            </button>
            <div class="collapse navbar-collapse" id="navMenu">
                <ul class="navbar-nav ms-auto gap-1">
                    @foreach (var s in navSections.Where(s => s.Enabled && s.Key != "hero").OrderBy(s => s.Order))
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="#@s.Key">@(char.ToUpper(s.Key[0]) + s.Key[1..])</a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="site-footer text-center py-4">
        <div class="container">
            <p class="mb-0 text-muted small">
                @layoutTitles.FooterText &mdash; &copy; @DateTime.Now.Year @layoutTitles.FooterCredit
            </p>
        </div>
    </footer>

    <button id="backToTop" class="back-to-top" aria-label="Back to top" onclick="window.scrollTo({top:0,behavior:'smooth'})">
        <i class="bi bi-chevron-up"></i>
    </button>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
