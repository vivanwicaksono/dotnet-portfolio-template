@model VivanPortfolio.Models.PortfolioViewModel
@{
    ViewData["Title"] = Model.Profile.Name + " — Portfolio";
}

@foreach (var section in Model.SectionSettings.Where(s => s.Enabled).OrderBy(s => s.Order))
{
    if (section.Key == "hero")
    {
        @await Html.PartialAsync("Partials/_Hero", Model)
    }
    else if (section.Key == "about")
    {
        @await Html.PartialAsync("Partials/_About", Model)
    }
    else if (section.Key == "experience")
    {
        @await Html.PartialAsync("Partials/_Experience", Model)
    }
    else if (section.Key == "skills")
    {
        @await Html.PartialAsync("Partials/_Skills", Model)
    }
    else if (section.Key == "education")
    {
        @await Html.PartialAsync("Partials/_Education", Model)
    }
    else if (section.Key == "certifications")
    {
        @await Html.PartialAsync("Partials/_Certifications", Model)
    }
    else if (section.Key == "testimonials")
    {
        @await Html.PartialAsync("Partials/_Testimonials", Model)
    }
    else if (section.Key == "contact")
    {
        @await Html.PartialAsync("Partials/_Contact", Model)
    }
}
