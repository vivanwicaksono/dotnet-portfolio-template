@model VivanPortfolio.Models.PortfolioViewModel
@{
    var fields = Model.FieldSettings.Contact;
    var titles = Model.TitleSettings.Contact;
}

<!-- ════════════════════════════ CONTACT ═══════════════════════════════ -->
<section class="section-block contact-section" id="contact">
    <div class="container text-center">
        <div class="section-header">
            <span class="section-tag">@titles.Tag</span>
            <h2 class="section-title">@titles.Title</h2>
        </div>
        <p class="contact-sub">@titles.Description</p>
        <div class="contact-actions d-flex flex-wrap justify-content-center gap-3 mt-5">
            @if (fields.Email)
            {
                <a href="mailto:@Model.Profile.Email" class="btn btn-contact">
                    <i class="bi bi-envelope-fill me-2"></i>@titles.EmailButton
                </a>
            }
            @if (fields.LinkedIn)
            {
                <a href="@Model.Profile.LinkedInUrl" target="_blank" rel="noopener" class="btn btn-contact-linkedin">
                    <i class="bi bi-linkedin me-2"></i>@titles.LinkedInButton
                </a>
            }
            @if (fields.Fiverr)
            {
                <a href="@Model.Profile.FiverrUrl" target="_blank" rel="noopener" class="btn btn-contact-fiverr">
                    <i class="bi bi-briefcase me-2"></i>@titles.FiverrButton
                </a>
            }
            @if (fields.Upwork)
            {
                <a href="@Model.Profile.UpworkUrl" target="_blank" rel="noopener" class="btn btn-contact-upwork">
                    <i class="bi bi-briefcase me-2"></i>@titles.UpworkButton
                </a>
            }
            @if (fields.Toptal)
            {
                <a href="@Model.Profile.ToptalUrl" target="_blank" rel="noopener" class="btn btn-contact-toptal">
                    <i class="bi bi-briefcase me-2"></i>@titles.ToptalButton
                </a>
            }
            @if (fields.Freelancer)
            {
                <a href="@Model.Profile.FreelancerUrl" target="_blank" rel="noopener" class="btn btn-contact-freelancer">
                    <i class="bi bi-briefcase me-2"></i>@titles.FreelancerButton
                </a>
            }
            @if (fields.Guru)
            {
                <a href="@Model.Profile.GuruUrl" target="_blank" rel="noopener" class="btn btn-contact-guru">
                    <i class="bi bi-briefcase me-2"></i>@titles.GuruButton
                </a>
            }
            @if (fields.PeoplePerHour)
            {
                <a href="@Model.Profile.PeoplePerHourUrl" target="_blank" rel="noopener" class="btn btn-contact-peopleperhour">
                    <i class="bi bi-briefcase me-2"></i>@titles.PeoplePerHourButton
                </a>
            }
        </div>
    </div>
</section>
